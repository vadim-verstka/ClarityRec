# API Key для доступа к ClarityRec Core
# Сгенерируйте уникальный ключ и используйте его в заголовке X-API-Key
API_KEY=clarity-rec-demo-api-key-2024

# Порт сервера
PORT=3001

# Режим работы (development/production)
NODE_ENV=development

# Разрешенные CORS origins (через запятую, * для всех в dev)
CORS_ORIGINS=*
