# API ключ для взаимодействия между сервисами
CLARITYREC_API_KEY=clarity-rec-secret-key-2024

# JWT секрет для аутентификации
JWT_SECRET=super-secret-jwt-key-change-in-prod

# URL сервиса рекомендаций
CORE_SERVICE_URL=http://clarityrec-core:3000

# Порт бэкенда
PORT=3000

# Режим работы
NODE_ENV=production
